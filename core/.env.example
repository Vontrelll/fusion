# ==================== Fusion App Environment Variables ====================

# === REQUIRED ===
SECRET_KEY=your-super-long-random-secret-key-here

# Change to False when going live
DEBUG=True

# For local development
ALLOWED_HOSTS=127.0.0.1,localhost

# === Database (Supabase) - Replace with your own values ===
DB_NAME=postgres
DB_USER=your-project-ref.postgres
DB_PASSWORD=your-supabase-password
DB_HOST=your-pooler-host.supabase.com
DB_PORT=5432

# === Production (required before shipping MVP) ===
# DEBUG=False
# ALLOWED_HOSTS=fusionbeta.com,www.fusionbeta.com
# SECRET_KEY=<generate-a-long-random-string-never-use-the-dev-fallback>
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# === Email via Resend (recommended for password reset in prod) ===
# Replace re_xxxxxxxxx with your real API key from https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxx
# DEFAULT_FROM_EMAIL=onboarding@resend.dev
# For production, use an address on a domain you've verified in Resend:
# DEFAULT_FROM_EMAIL=noreply@resetpassword.fusionbeta.com
# SITE_BASE_URL=https://fusionbeta.com
# Links in password-reset emails (subdomain must point at your app + be in ALLOWED_HOSTS):
# PASSWORD_RESET_DOMAIN=resetpassword.fusionbeta.com

# === Legacy SMTP (optional alternative to Resend) ===
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.yourprovider.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@fusionbeta.com
# EMAIL_HOST_PASSWORD=your-smtp-password
# EMAIL_USE_TLS=True