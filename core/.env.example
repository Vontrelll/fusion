# ==================== Fusion App Environment Variables ====================

# === REQUIRED ===
SECRET_KEY=your-super-long-random-secret-key-here

# Change to False when going live
DEBUG=True

# For local development
ALLOWED_HOSTS=127.0.0.1,localhost

# === Database (Supabase) - Replace with your own values ===
DB_NAME=postgres
DB_USER=your-project-ref.postgres
DB_PASSWORD=your-supabase-password
DB_HOST=your-pooler-host.supabase.com
DB_PORT=5432

# === Future Production Settings (uncomment when deploying) ===
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com