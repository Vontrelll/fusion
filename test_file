from typing import Any


class Event:
    next_id = 1
    def __init__(self, id, name, start_time, end_time, location, kid_name):
        self.name = name 
        self.start_time = start_time
        self.end_time = end_time
        self.location = location
        self.kid_name = kid_name
        self.id = Event.next_id 
        Event.next_id += 1


def add_event(id, name, start_time, end_time, location, kid_name):
    event = Event(id, name, start_time, end_time, location, kid_name)
    conflict = has_conflict(event)

    if conflict:
        return None


    event_list.append(event)

    return event


def list_events():
    print("Here are all your events:")
    for event in event_list:
        print(f"{event.name} starts at {event.start_time}")


def has_conflict(new_event):

    for event in event_list:
        if (new_event.start_time < event.end_time) and (new_event.end_time > event.start_time):
            return True

        return False 

def delete_event(event_id):
    for i, item in enumerate(event_list):
        if item.id == event_id:
            event_list.pop(i)
            return True 
            
    return False 



